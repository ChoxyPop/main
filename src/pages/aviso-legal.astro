---
import { getEntry, render } from "astro:content";
import Markdown from "@components/common/Markdown.astro";
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import dayjs from "dayjs";

const entryName = "aviso-legal"; 
const entry = await getEntry("spec", entryName);

if (!entry) {
	throw new Error(`Archivo Markdown no encontrado en src/content/spec/${entryName}.md`);
}

const { Content, remarkPluginFrontmatter } = await render(entry);

const title = remarkPluginFrontmatter?.title || entry.data?.title || "Sin título";
const description = remarkPluginFrontmatter?.description || entry.data?.description || "";

// Extraer fecha: buscamos 'updated', luego 'published', luego 'lastMod'
const rawDate = remarkPluginFrontmatter?.updated || 
                remarkPluginFrontmatter?.published || 
                remarkPluginFrontmatter?.lastMod || 
                entry.data?.updated || 
                new Date();

const dateStr = dayjs(rawDate).format("YYYY-MM-DD");
const pageIcon = "material-symbols:shield-lock"; 
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
          <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
            <Icon name={pageIcon} class="text-[1.5rem]"></Icon>
          </div>
          <h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            {title}
          </h1>
        </div>
        
        {description && (
          <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
            {description}
          </p>
        )}
      </div>
      
      <Markdown class="mt-2">
        <Content />
      </Markdown>
    </div>
  </div>

  <div class="card-base p-6 mt-4 mb-4">
    <div class="flex items-center gap-2">
      <div class="transition h-9 w-9 rounded-lg overflow-hidden relative flex items-center justify-center mr-0">
        <Icon
          name="material-symbols:history-rounded"
          class="text-4xl text-(--primary) bg-(--enter-btn-bg) p-2 rounded-md"
        />
      </div>
      <div class="flex flex-col gap-0.1">
        <div class="text-[1.0rem] leading-tight text-black/75 dark:text-white/75">
          {i18n(I18nKey.lastModifiedPrefix)}{dateStr}
        </div>
        <p class="text-[0.8rem] leading-tight text-black/75 dark:text-white/75 opacity-60">
          Documento legal del sitio
        </p>
      </div>
    </div>
  </div>
</MainGridLayout>